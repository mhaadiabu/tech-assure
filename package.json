{
  "name": "_scaffold",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@clerk/nextjs": "^7.0.5",
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "recharts": "^3.8.0",
      "sonner": "^2.0.5",
      "convex": "^1.33.1",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @_scaffold/backend dev",
    "dev:setup": "turbo -F @_scaffold/backend dev:setup"
  },
  "dependencies": {
    "@_scaffold/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@_scaffold/config": "workspace:*",
    "turbo": "^2.9.8",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
