# Convex deployment + URLs. These are usually populated automatically
# by `npx convex dev` for local dev, but they are also accepted from
# .env.local so the same file works in CI and on the Convex dashboard.

CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# JWT issuer domain for the Clerk auth provider. Configured in the
# Convex dashboard for prod, but accepted from .env.local for `convex dev`.
# Use the Clerk Frontend API URL, e.g. https://enhanced-deer-72.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=
