# Public Clerk key. Safe to commit.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Server-side Clerk secret. NEVER commit a real value.
CLERK_SECRET_KEY=

# Clerk JWT issuer domain. Must match the Clerk Frontend API URL (e.g.
# https://enhanced-deer-72.clerk.accounts.dev). Used to construct the
# Convex tokenIdentifier for webhook-synced users so they match what
# Clerk provides during sign-in.
CLERK_JWT_ISSUER_DOMAIN=

# Convex deployment URL used by the web app to reach the backend.
# Must match CONVEX_URL in packages/backend/.env.example.
NEXT_PUBLIC_CONVEX_URL=

# Optional Clerk redirect URLs. If unset, the layout uses
# /sign-in, /sign-up, /dashboard as defaults.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook signing secret. Used to verify the authenticity of webhook
# events at /api/webhooks/clerk. Configure a webhook in the Clerk dashboard
# pointing to <your-deployment>/api/webhooks/clerk and subscribe to
# user.created and user.updated events.
CLERK_WEBHOOK_SIGNING_SECRET=
